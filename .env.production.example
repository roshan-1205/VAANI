# AWS Amplify Production Environment Variables
# Copy these to Amplify Console → App Settings → Environment Variables

# Backend API URL (Update with your deployed backend URL)
VITE_API_URL=https://your-backend-api.com

# Firebase Configuration
# Get these from Firebase Console → Project Settings → Your Apps
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# Optional: Firebase Measurement ID (for Analytics)
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# AWS Configuration (if needed for direct AWS SDK usage)
# VITE_AWS_REGION=us-east-1
# VITE_AWS_ACCESS_KEY_ID=your_aws_access_key
# VITE_AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# Note: Never commit actual values to Git!
# These are examples only - replace with your actual values in Amplify Console
